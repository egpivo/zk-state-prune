# Per-developer sanity-check runs are ephemeral — every
# `make scroll-smoke` overwrites the contents, so committing them
# is just churn. Only the headline experiment runs (e.g.
# scroll_100k/) land in git.
scroll_smoke/

# Universal: SQLite + extractor logs from any run dir. Even
# inside a committed experiment dir we don't want the DB or the
# stderr log — they balloon and they're locally regeneratable.
*.db
*.db-shm
*.db-wal
extract.log

# qa-robustness debug log — full `go test -v` capture, several
# thousand lines, regenerable in seconds. The aggregated JSON
# summary lands beside it and IS committable.
robustness_run.log
*.stderr

# Persisted Cox model is locally regeneratable from cox.json + the DB
# via `zksp fit --model cox`; the binary blob has no diff value.
cox.model

# Rolling-backtest artifacts (per-fold cox.model.json + summary +
# HTML) — regeneratable from scroll.db + git commit; multi-MB.
backtest/
